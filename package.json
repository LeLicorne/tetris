{
  "name": "tetris-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "format": "prettier --ignore-path .prettierignore --ignore-path .gitignore --check \"**/*.+(js|json|ts|tsx)\"",
    "format:fix": "prettier --ignore-path .prettierignore --ignore-path .gitignore --write \"**/*.+(js|json|ts|tsx)\"",
    "lint": "eslint ./src --max-warnings=0",
    "lint:fix": "eslint ./src --max-warnings=0 --fix",
    "validate": "npm-run-all2 --parallel typecheck lint format",
    "preview": "vite preview",
    "prepare": "husky",
    "typecheck": "tsc --project tsconfig.json --noEmit"
  },
  "dependencies": {
    "@reduxjs/toolkit": "2.11.2",
    "@tanstack/react-router": "1.169.1",
    "firebase": "12.12.1",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-redux": "9.2.0",
    "redux-persist": "6.0.0",
    "tailwind-merge": "3.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "4.2.4",
    "@tanstack/router-devtools": "1.166.13",
    "@tanstack/router-plugin": "1.167.33",
    "@types/node": "24.12.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "autoprefixer": "10.5.0",
    "eslint": "9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "globals": "17.5.0",
    "husky": "^9.1.7",
    "postcss": "8.5.14",
    "npm-run-all2": "8.0.4",
    "prettier": "^3.8.3",
    "tailwindcss": "4.2.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "8.0.10"
  }
}
